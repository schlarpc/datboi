/// datboi:transform — the versioned transform ABI (D7).
///
/// STATUS: FROZEN @ M1 (prototype 3). This is `@1`, the *whole-buffer*
/// profile: each input and output is a complete byte blob passed by value.
/// It is the correct shape for bounded transforms (header add/strip,
/// byte/word swaps, small patches) and is what the M1 determinism gate
/// exercises.
///
/// A *streaming* profile (host-backed pull/push resources, for multi-GB
/// ISOs) is a deliberate FUTURE world `datboi:transform@2`, NOT a
/// replacement: per D7 old worlds stay executable forever, so `@1`
/// components keep running unchanged after `@2` ships. "Which world a
/// component targets" is recipe metadata, so a recipe is never ambiguous
/// about how to invoke its component.
///
/// Determinism contract (D5): the host runs components with NaN
/// canonicalization ON, threads OFF, relaxed-SIMD OFF, and NO ambient
/// capabilities (no clock, random, or filesystem) — `params` plus the input
/// bytes are the entire world. The same inputs MUST produce byte-identical
/// outputs on every host and architecture, forever. Two enforcement layers:
/// the empty import surface makes ambient nondeterminism unrepresentable,
/// and the wasmtime `Config` pins the remaining engine-level knobs.
package datboi:transform@1.0.0;

interface types {
    /// Seekability class a transform declares for its output
    /// (docs/80-views.md, D27). Carried as metadata even in the whole-buffer
    /// profile so the view planner can classify a transform's random-access
    /// cost without needing a streaming ABI.
    enum seek-class {
        /// Output ranges map to input ranges arithmetically (swaps, headers).
        affine,
        /// Random access via a content-addressed index (frame/block tables).
        manifest-seekable,
        /// Whole-stream only; range reads require full materialization first.
        opaque,
    }

    /// Static, pure metadata the host reads before running a transform.
    record descriptor {
        seek: seek-class,
        /// Input positions that require random access — the host must
        /// materialize a non-seekable source before calling
        /// (docs/70-recipes.md execution model). Empty for whole-buffer
        /// transforms.
        random-access-inputs: list<u32>,
    }
}

world transform {
    use types.{descriptor, seek-class};

    /// Describe an operation's capabilities. Must be pure and constant for
    /// a given `op` — the host may cache the result by component hash.
    export describe: func(op: string) -> descriptor;

    /// Apply one operation (one recipe). `op` selects the operation within
    /// the component, `params` is the recipe's canonical-CBOR params bstr
    /// verbatim, and `inputs` are the resolved input blobs in recipe order.
    /// Returns the claimed output blobs in recipe order (multi-output
    /// transforms — e.g. archive members — are supported), or an error
    /// message. The host verifies output hashes against the recipe (D4), so
    /// a buggy transform wastes CPU but cannot corrupt the store.
    export run: func(
        op: string,
        params: list<u8>,
        inputs: list<list<u8>>,
    ) -> result<list<list<u8>>, string>;
}
