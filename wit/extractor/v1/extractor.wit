/// datboi:extractor@1 — the extractor lane (D89 epoch, ruled 2026-07-14;
/// interaction model descends from D58's pathfinder, reshaped where its
/// own shipping code was already asking).
///
/// An extractor opens a CONTAINER — seekable archive stream(s) in, member
/// streams + metadata out — where a transform maps input bytes to claimed
/// output bytes. Extraction is inherently seek-driven (header walks,
/// solid-block restarts), so containers always arrive seekable — the host
/// materializes non-seekable routes first (spill rule, docs/recipes.md).
///
/// The D89 reshapes, each with its forcing function:
///
/// * `archives` is a LIST — the recipe model was already plural and the
///   old world was the only place in the pipeline hard-coding one
///   container. Multi-volume sets are POLICY (v1 components refuse
///   them), not ABI. Single-volume passes a one-element list, and `ix`
///   identity is defined over the WHOLE ordered container list.
/// * `extract` takes a request BATCH — the single-member signature made
///   solid-archive ingest O(n²) (each call decodes and discards all
///   solid predecessors; the host cannot amortize from outside because
///   every run is a fresh deterministic instance). Replay stays
///   per-member: a recipe rebuilds one member with a one-request batch.
///   Determinism clause, gate-tested with subset properties: member
///   bytes are a PURE FUNCTION of (containers, ix) regardless of the
///   request set.
/// * both exports take `params` — the recipe layer was already smuggling
///   a params bstr around the wit. Empty means "no options"; a component
///   REFUSES params it does not understand (params are recipe content —
///   two encodings of "the same" params must not both work). Passwords
///   and charset hints become CBOR keys here, never lane increments.
///
/// `enumerate` returns a canonical-CBOR member list (D89 vocabulary
/// rule): `{1: [member...]}` where member is `{1: ix, 2: name, 3: size,
/// 4: packed-size, 5: crc32, 6: solid}` — schema documented in
/// `datboi-guest-extractor` beside the encoders. `ix` is the member's
/// stable identity within the ordered container list (files only, listed
/// order — directories, links and NTFS streams are not listed and do not
/// consume an index): derive recipes pin (containers, ix), and `extract`
/// addresses members by it. `name` is metadata, never an identity.
/// Added keys must be ADVISORY-ONLY (D64; docs/worlds.md).
///
/// Determinism contract (D5/D46): the only imports are
/// `datboi:streams/types@1` — see that package for the exact read/write
/// contract. Fuel meters guest instructions only.
///
/// Error surface (ruled with D58, carried whole): a trap REFUSES THE
/// WHOLE ARCHIVE — the guest maps internal failure paths (a vendored
/// parser's error handler, allocation failure, any diagnostic abort)
/// onto wasm `unreachable`, matching the refuse-suspicious-archives
/// posture. A `result` error is the polite twin (recognizably corrupt
/// data, refused feature) — the host treats both as refusal; neither
/// ever yields partial member bytes as success. The wasmtime memory cap
/// turns decompression bombs into clean refusals.
///
/// Versioning (docs/worlds.md): every published version is immutable
/// forever.
package datboi:extractor@1.0.0;

interface types {
    use datboi:streams/types@1.0.0.{sink};

    /// One member to decode in this `extract` call, paired with the sink
    /// its bytes stream into. The host hash-tees every sink (D4).
    record extract-request {
        /// Member identity as numbered by `enumerate`.
        ix: u32,
        out: sink,
    }
}

world extractor {
    use types.{extract-request};
    use datboi:streams/types@1.0.0.{file};

    /// Enumerate the containers' file members as canonical CBOR (schema
    /// above). Refuses (error) container sets the component does not
    /// support, encrypted archives it cannot open, params it does not
    /// understand, and containers whose headers do not parse. Pure
    /// metadata: no member bytes are decoded beyond what the header walk
    /// requires.
    export enumerate: func(
        archives: list<file>,
        params: list<u8>,
    ) -> result<list<u8>, string>;

    /// Decode every requested member into its sink, running to
    /// completion. Each member's bytes MUST equal its unpacked bytes
    /// exactly — the host verifies against the claimed hash (D4), so a
    /// buggy extractor wastes CPU but cannot corrupt the store — and
    /// MUST be a pure function of (containers, ix): the request set may
    /// change decode COST (one solid pass instead of n), never bytes.
    /// Solid archives decode predecessor members internally (discarded
    /// where not requested).
    export extract: func(
        archives: list<file>,
        params: list<u8>,
        requests: list<extract-request>,
    ) -> result<_, string>;
}
