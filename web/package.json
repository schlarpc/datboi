    "wuchale": "^0.25.6"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@testing-library/svelte": "^5.4.2",
    "@tsconfig/svelte": "^5.0.8",
    "@types/node": "^26.1.1",
    "happy-dom": "^20.10.6",
    "openapi-typescript": "^7.13.0",
    "svelte-check": "^4.7.2",
    "typescript": "^5.9.3",
